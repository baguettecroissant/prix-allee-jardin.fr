---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWidget from '../components/QuoteWidget.astro';
import PriceTable from '../components/PriceTable.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQ from '../components/FAQ.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { siteConfig } from '../../site.config';
import { getAllCities, getCityBySlug, getNearbyCities } from '../lib/cities';
import { blogArticles } from '../data/blog-articles';
import localContentRaw from '../data/local-content.json';

const localContent = localContentRaw as Record<string, {
  intro: string; local_tip: string; history_anecdote: string;
  faq_local: { question: string; answer: string }; market_data: string;
  external_links: { label: string; url: string; desc: string }[];
  internal_links: { label: string; url: string }[];
}>;

export function getStaticPaths() {
  return getAllCities().map(city => ({ params: { city: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const nearbyCities = getNearbyCities(city, 8);
const lc = localContent[city.slug];
const seed = city.slug.split('').reduce((a, c) => a + c.charCodeAt(0), 0);

const title = siteConfig.niche.seoTitleTemplate.replace('{city}', city.name).replace('{zip}', city.zip);
const description = siteConfig.niche.metaDescTemplate.replace('{city}', city.name).replace('{zip}', city.zip);

const faqItems = [...siteConfig.faq.slice(0, 4), ...(lc ? [{ q: lc.faq_local.question, a: lc.faq_local.answer }] : [])];

// Pick 3 blog articles for maillage interne (deterministic)
const blogLinks = [...blogArticles].sort((a, b) => {
  const ha = a.slug.charCodeAt(seed % a.slug.length);
  const hb = b.slug.charCodeAt(seed % b.slug.length);
  return ha - hb;
}).slice(0, 3);

const zone = city.region.includes('Hauts-de-France') || city.region.includes('Grand Est') || city.region.includes('Bourgogne') ? 'H1' :
             city.region.includes('PACA') || city.region.includes('Corse') ? 'H3' : 'H2';

const jsonLd = [
  { "@context": "https://schema.org", "@type": "Service", "name": `${siteConfig.niche.name} à ${city.name}`, "description": description,
    "areaServed": { "@type": "City", "name": city.name, "postalCode": city.zip },
    "provider": { "@type": "LocalBusiness", "name": siteConfig.name, "url": `https://www.${siteConfig.domain}/${city.slug}` } },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://www.${siteConfig.domain}` },
    { "@type": "ListItem", "position": 2, "name": "Annuaire", "item": `https://www.${siteConfig.domain}/annuaire` },
    { "@type": "ListItem", "position": 3, "name": city.deptName, "item": `https://www.${siteConfig.domain}/departement/${city.deptCode.toLowerCase()}` },
    { "@type": "ListItem", "position": 4, "name": city.name }
  ]},
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqItems.map(f => ({
    "@type": "Question", "name": f.q.replace('{city}', city.name),
    "acceptedAnswer": { "@type": "Answer", "text": f.a.replace('{city}', city.name) }
  }))}
];

const benefits = [
  `Paysagistes **qualifiés** dans le ${city.deptName} (${city.deptCode})`,
  `Matériaux adaptés au **sol ${zone === 'H1' ? 'et au gel' : zone === 'H3' ? 'et au climat sec' : 'local'}**`,
  `Conformité **PLU** de ${city.name}`,
  `Valorisation de votre **propriété**`,
  `**Drainage** et perméabilité optimisés`,
  `Garantie **décennale** obligatoire`,
].sort((a, b) => a.charCodeAt(seed % a.length) - b.charCodeAt(seed % b.length));
---

<BaseLayout title={title} description={description} canonical={`/${city.slug}`} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Annuaire", href: "/annuaire" },
        { label: city.deptName, href: `/departement/${city.deptCode.toLowerCase()}` },
        { label: city.name, href: `/${city.slug}` },
      ]} />
      <div class="grid lg:grid-cols-5 gap-10 items-start mt-6">
        <div class="lg:col-span-3">
          <h1 class="text-2xl md:text-4xl font-extrabold leading-tight mb-6">
            Allée de Jardin à {city.name} ({city.zip})<br/>
            <span class="text-brand-200 text-xl md:text-2xl font-bold">Prix & Devis Gratuit 2026</span>
          </h1>
          <div class="mb-8">
            <p class="text-green-100 leading-relaxed" set:html={lc?.intro || `Comparez gratuitement 3 devis de paysagistes qualifiés à **${city.name}** (${city.zip}), ${city.deptName}. Service 100% gratuit.`.replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>')} />
          </div>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {benefits.map((b) => (
              <div class="flex items-start gap-2 bg-white/5 backdrop-blur-sm rounded-lg px-4 py-3 border border-white/10">
                <span class="text-green-400 mt-0.5">✓</span>
                <span class="text-sm text-green-100" set:html={b.replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>')} />
              </div>
            ))}
          </div>
          <a href="/devis" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3.5 rounded-xl transition-colors shadow-lg cta-btn">
            🌳 Comparer 3 Devis à {city.name}
          </a>
        </div>
        <div class="lg:col-span-2" id="devis-form">
          <div class="sticky top-20"><QuoteWidget keyword={`${siteConfig.niche.name} ${city.name}`} /></div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">

    {/* Expert Content */}
    {lc && (
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">🌳 Créer une allée de jardin à {city.name} ({city.deptCode})</h2>
        <div class="prose max-w-none text-gray-600 space-y-4">
          <p>{lc.intro}</p>
          <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-r-lg my-6">
            <h3 class="text-green-900 font-bold text-base mb-2">💡 Conseil local — {city.name}</h3>
            <p class="text-green-800 text-sm" set:html={lc.local_tip} />
          </div>
          <p class="italic text-gray-500 border-l-2 border-gray-200 pl-4">📜 {lc.history_anecdote}</p>
        </div>
      </section>
    )}

    {/* Market Data */}
    {lc?.market_data && (
      <section class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200 p-6 md:p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-3">📊 Baromètre des prix — {city.deptName} ({city.deptCode})</h2>
        <p class="text-gray-700 leading-relaxed">{lc.market_data}</p>
        <p class="text-sm text-gray-500 mt-3">→ <a href="/blog/prix-allee-jardin-2026" class="text-brand-600 hover:underline">Voir notre guide complet des prix 2026</a></p>
      </section>
    )}

    {/* Price Table */}
    <section>
      <p class="text-sm text-gray-500 mb-4">💡 À {city.name} ({city.region}), les tarifs varient de ±{zone === 'H1' ? '15' : '10'}% selon le terrain et les matériaux.</p>
      <PriceTable />
    </section>

    {/* Materials Guide */}
    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">⚙️ Comparatif matériaux à {city.name}</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead><tr class="bg-gray-50 text-gray-500 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold">Matériau</th>
            <th class="px-4 py-3 text-left font-semibold">Prix/m²</th>
            <th class="px-4 py-3 text-left font-semibold">Durabilité</th>
            <th class="px-4 py-3 text-left font-semibold">Carrossable</th>
          </tr></thead>
          <tbody class="divide-y divide-gray-100">
            <tr><td class="px-4 py-3">Gravier stabilisé</td><td class="px-4 py-3 font-bold text-brand-600">30 – 60€</td><td class="px-4 py-3">⭐⭐⭐</td><td class="px-4 py-3">⚠️ Limité</td></tr>
            <tr class="bg-green-50 font-semibold"><td class="px-4 py-3 text-green-800">✅ Pavés autobloquants</td><td class="px-4 py-3 text-green-700">50 – 90€</td><td class="px-4 py-3 text-green-700">⭐⭐⭐⭐⭐</td><td class="px-4 py-3 text-green-700">✅ Oui</td></tr>
            <tr><td class="px-4 py-3">Béton désactivé</td><td class="px-4 py-3 font-bold text-brand-600">60 – 100€</td><td class="px-4 py-3">⭐⭐⭐⭐⭐</td><td class="px-4 py-3">✅ Oui</td></tr>
            <tr><td class="px-4 py-3">Pierre naturelle</td><td class="px-4 py-3 font-bold text-brand-600">80 – 150€</td><td class="px-4 py-3">⭐⭐⭐⭐⭐</td><td class="px-4 py-3">✅ Oui</td></tr>
            <tr><td class="px-4 py-3">Résine drainante</td><td class="px-4 py-3 font-bold text-brand-600">50 – 90€</td><td class="px-4 py-3">⭐⭐⭐⭐</td><td class="px-4 py-3">⚠️ Piéton</td></tr>
            <tr><td class="px-4 py-3">Béton imprimé</td><td class="px-4 py-3 font-bold text-brand-600">70 – 120€</td><td class="px-4 py-3">⭐⭐⭐⭐</td><td class="px-4 py-3">✅ Oui</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-gray-500 mt-4">→ <a href="/blog/erreurs-eviter-allee-jardin" class="text-brand-600 hover:underline">Les 5 erreurs à éviter</a> • <a href="/blog/entretien-allee-jardin" class="text-brand-600 hover:underline">Entretien par matériau</a></p>
    </section>

    {/* External Links — Ressources officielles */}
    {lc?.external_links && (
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">🔗 Ressources officielles — {city.name}</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {lc.external_links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 bg-gray-50 rounded-xl p-4 hover:bg-brand-50 hover:border-brand-200 border border-gray-100 transition-all group">
              <span class="text-brand-600 mt-0.5">↗</span>
              <div>
                <span class="font-semibold text-sm text-gray-900 group-hover:text-brand-600">{link.label}</span>
                <span class="block text-xs text-gray-400 mt-0.5">{link.desc}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <ProcessSteps />

    {/* FAQ */}
    {lc ? (
      <FAQ items={[...siteConfig.faq, { q: lc.faq_local.question, a: lc.faq_local.answer }]} cityName={city.name} />
    ) : (
      <FAQ items={siteConfig.faq} cityName={city.name} />
    )}

    {/* MAILLAGE INTERNE — Blog Articles */}
    <section>
      <h2 class="text-xl font-bold text-gray-900 mb-4">📚 Nos guides pour votre allée à {city.name}</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {blogLinks.map((article) => (
          <a href={`/blog/${article.slug}`} class="bg-white border border-gray-200 rounded-xl p-5 hover:border-brand-300 hover:shadow-md transition-all group">
            <span class="text-2xl block mb-2">{article.emoji}</span>
            <span class="text-xs text-brand-600 font-medium">{article.category}</span>
            <h3 class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm mt-1 line-clamp-2">{article.title}</h3>
            <span class="text-xs text-gray-400 mt-2 block">{article.readTime}</span>
          </a>
        ))}
      </div>
      {lc?.internal_links && (
        <div class="mt-4 flex flex-wrap gap-2">
          {lc.internal_links.map((link) => (
            <a href={link.url} class="text-xs bg-brand-50 text-brand-700 px-3 py-1.5 rounded-full hover:bg-brand-100 transition-colors">
              → {link.label}
            </a>
          ))}
        </div>
      )}
    </section>

    {/* Nearby Cities */}
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">📍 Allée de Jardin près de {city.name}</h2>
      <p class="text-gray-500 text-sm mb-6">Nos paysagistes interviennent aussi dans le {city.deptName}</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {nearbyCities.map((nc) => (
          <a href={`/${nc.slug}`} class="bg-white border border-gray-200 rounded-xl px-4 py-3 hover:border-brand-300 hover:shadow-md transition-all group text-center">
            <span class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm block">{nc.name}</span>
            <span class="text-xs text-gray-400">{nc.zip} • {nc.deptName}</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-4">
        <a href={`/departement/${city.deptCode.toLowerCase()}`} class="text-brand-600 hover:text-brand-700 font-semibold text-sm">
          Voir toutes les villes du {city.deptName} →
        </a>
      </div>
    </section>

    {/* Final CTA */}
    <section class="pb-20 md:pb-0">
      <div class="bg-gradient-to-r from-brand-600 to-brand-800 rounded-2xl p-8 text-center text-white">
        <h2 class="text-xl md:text-2xl font-bold mb-3">Obtenez vos 3 devis Allée de Jardin à {city.name}</h2>
        <p class="text-brand-100 mb-5 text-sm">Gratuit • Sans engagement • Paysagistes du {city.deptName}</p>
        <a href="/devis" class="inline-block bg-white text-brand-700 font-bold px-8 py-3.5 rounded-xl hover:bg-brand-50 transition-colors shadow-lg cta-btn">Demander mes devis →</a>
      </div>
    </section>
  </div>
</BaseLayout>
